{
    "version": 1,
    "project": "ssserve",
    "project_url": "https://github.com/prakashsellathurai/ssserve",
    "repo": ".",
    "branches": ["main"],
    "show_commit_url": "https://github.com/prakashsellathurai/ssserve/commit/",
    "pythons": ["3.12"],
    "environment_type": "virtualenv",
    "benchmark_dir": "benchmarks",
    "env_dir": ".asv/env",
    "results_dir": ".asv/results",
    "html_dir": ".asv/html",
    "default_benchmark_timeout": 60,
    "build_command": [
        "PIP_NO_BUILD_ISOLATION=0 python -m build",
        "python -m pip wheel --no-deps -w {build_cache_dir} {build_dir}"
    ]
}
